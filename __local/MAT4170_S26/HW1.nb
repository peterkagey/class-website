Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"HueToHex", "[", "h_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "rgb", "}"}], ",", 
    RowBox[{
     RowBox[{"rgb", "=", 
      RowBox[{"ColorConvert", "[", 
       RowBox[{
        RowBox[{"Hue", "[", "h", "]"}], ",", "\"\<RGB\>\""}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"StringJoin", "[", 
      RowBox[{"\"\<#\>\"", ",", 
       RowBox[{"IntegerString", "[", 
        RowBox[{
         RowBox[{"Round", "[", 
          RowBox[{"255", " ", 
           RowBox[{"rgb", "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], "]"}], ",", "16", ",", "2"}], 
        "]"}], ",", 
       RowBox[{"IntegerString", "[", 
        RowBox[{
         RowBox[{"Round", "[", 
          RowBox[{"255", " ", 
           RowBox[{"rgb", "[", 
            RowBox[{"[", "2", "]"}], "]"}]}], "]"}], ",", "16", ",", "2"}], 
        "]"}], ",", 
       RowBox[{"IntegerString", "[", 
        RowBox[{
         RowBox[{"Round", "[", 
          RowBox[{"255", " ", 
           RowBox[{"rgb", "[", 
            RowBox[{"[", "3", "]"}], "]"}]}], "]"}], ",", "16", ",", "2"}], 
        "]"}]}], "]"}]}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"Hue", "[", 
  RowBox[{"0.3", ",", "1", ",", "0.5"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"Table", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"HueToHex", "[", 
    RowBox[{"Hue", "[", 
     RowBox[{
      FractionBox["n", "6"], ",", "1", ",", "0.5"}], "]"}], "]"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{"n", ",", "0", ",", "5"}], "}"}]}], "\[IndentingNewLine]", 
  "]"}]}], "Input",
 CellChangeTimes->{{3.9787276506111298`*^9, 3.978727761457345*^9}, {
  3.978727799194806*^9, 3.978727806356827*^9}},
 CellLabel->"In[41]:=",ExpressionUUID->"651f4b35-390b-4b1c-944c-adae32ec6535"],

